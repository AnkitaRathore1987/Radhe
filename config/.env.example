# ─────────────────────────────────────────────────────────
# MINI-ALADDIN — Environment Config
# ─────────────────────────────────────────────────────────
# IMPORTANT: Yeh file KABHI bhi Git mein push mat karna
# .gitignore mein .env already listed hai
# ─────────────────────────────────────────────────────────

# ── UPSTOX API ───────────────────────────────────────────
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_ACCESS_TOKEN=         # Daily refresh hota hai — startup script fill karega
UPSTOX_REDIRECT_URI=http://localhost:3000/callback

# Backup broker (Phase 2 mein activate karenge)
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=

# ── SEBI COMPLIANCE ──────────────────────────────────────
SEBI_ALGO_ID=                # Upstox se milega after registration
STATIC_IP=                   # Oracle VPS ka public IP — whitelist hoga

# ── SERVER ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── REDIS ────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=              # Production mein strong password set karo

# ── POSTGRESQL ───────────────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=minialaddin
PG_USER=aladdin_user
PG_PASSWORD=                 # Strong password set karo

# ── TELEGRAM ALERTS ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # @BotFather se milega
TELEGRAM_CHAT_ID=            # Tumhara personal chat ID

# ── RISK LIMITS ──────────────────────────────────────────
ACCOUNT_CAPITAL=200000       # Rs 2 lakh Phase 1 start
DAILY_LOSS_LIMIT_PCT=1.5     # 1.5% of capital = Rs 3000 max daily loss
WEEKLY_LOSS_LIMIT_PCT=4.0    # 4% of capital weekly
RISK_PER_TRADE_PCT=0.5       # 0.5% per trade = Rs 1000 risk per trade
MAX_OPEN_POSITIONS=2         # Phase 1: max 2 positions at once
MAX_EXPOSURE_PCT=8.0         # Max 8% in single symbol

# ── KILL SWITCH ──────────────────────────────────────────
KILL_SWITCH_TELEGRAM_CMD=/KILLSWITCH
RESUME_TELEGRAM_CMD=/RESUME
